<Window x:Class="AveenoBudget.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AveenoBudget.ViewModels"
        Title="붐붐미(w)"
        Width="1200" Height="780"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- 최상위 Grid: 사이드바 | 콘텐츠 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>   <!-- 사이드바 -->
            <ColumnDefinition Width="*"/>     <!-- 메인 콘텐츠 -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════
             왼쪽 사이드바
        ══════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}">
            <DockPanel>

                <!-- 앱 로고 -->
                <Border DockPanel.Dock="Top"
                        Padding="0,18,0,12"
                        BorderBrush="#3A6DAB"
                        BorderThickness="0,0,0,1">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- 아이콘 원형 배경 -->
                        <Border Width="48" Height="48"
                                CornerRadius="24"
                                Background="#4A90D9"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,6">
                            <TextBlock Text="붐" FontSize="20" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="붐붐미(w)"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 메뉴 아이템들 -->
                <StackPanel DockPanel.Dock="Top"
                            Margin="8,12,8,0"
                            HorizontalAlignment="Center">

                    <!-- 지출관리 -->
                    <Button Style="{StaticResource SidebarMenuButtonStyle}"
                            Command="{Binding DataContext.RefreshCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0,0,0,4">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- 계산기 아이콘 (Path) -->
                            <Viewbox Width="28" Height="28" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Canvas.Left="3"  Canvas.Top="2"
                                               Width="18" Height="20" RadiusX="2" RadiusY="2"
                                               Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Rectangle Canvas.Left="6"  Canvas.Top="5"
                                               Width="12" Height="4"
                                               Fill="White" RadiusX="1" RadiusY="1"/>
                                    <Ellipse Canvas.Left="6"  Canvas.Top="12" Width="3" Height="3" Fill="White"/>
                                    <Ellipse Canvas.Left="10.5" Canvas.Top="12" Width="3" Height="3" Fill="White"/>
                                    <Ellipse Canvas.Left="15" Canvas.Top="12" Width="3" Height="3" Fill="White"/>
                                    <Ellipse Canvas.Left="6"  Canvas.Top="16.5" Width="3" Height="3" Fill="White"/>
                                    <Ellipse Canvas.Left="10.5" Canvas.Top="16.5" Width="3" Height="3" Fill="White"/>
                                    <Ellipse Canvas.Left="15" Canvas.Top="16.5" Width="3" Height="3" Fill="White"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="지출관리" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 목표관리 -->
                    <Button Style="{StaticResource SidebarMenuButtonStyle}"
                            Margin="0,0,0,4">
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="28" Height="28" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="2" Canvas.Top="2" Width="20" Height="20"
                                             Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Ellipse Canvas.Left="6" Canvas.Top="6" Width="12" Height="12"
                                             Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Ellipse Canvas.Left="10" Canvas.Top="10" Width="4" Height="4"
                                             Fill="White"/>
                                    <Line X1="12" Y1="2" X2="12" Y2="5"
                                          Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="12" Y1="19" X2="12" Y2="22"
                                          Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="2" Y1="12" X2="5" Y2="12"
                                          Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="19" Y1="12" X2="22" Y2="12"
                                          Stroke="White" StrokeThickness="1.5"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="목표관리" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 계정관리 -->
                    <Button Style="{StaticResource SidebarMenuButtonStyle}"
                            Margin="0,0,0,4">
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="28" Height="28" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Canvas.Left="3" Canvas.Top="2"
                                               Width="18" Height="20" RadiusX="2" RadiusY="2"
                                               Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="7" Y1="8"  X2="17" Y2="8"  Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="7" Y1="12" X2="17" Y2="12" Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="7" Y1="16" X2="13" Y2="16" Stroke="White" StrokeThickness="1.5"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="계정관리" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 카드등록 -->
                    <Button Style="{StaticResource SidebarMenuButtonStyle}"
                            Margin="0,0,0,4">
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="28" Height="28" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Canvas.Left="2" Canvas.Top="5"
                                               Width="20" Height="14" RadiusX="2" RadiusY="2"
                                               Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="2" Y1="10" X2="22" Y2="10"
                                          Stroke="White" StrokeThickness="2"/>
                                    <Rectangle Canvas.Left="5" Canvas.Top="13"
                                               Width="6" Height="3" RadiusX="1" RadiusY="1"
                                               Fill="White"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="카드등록" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 시재관리 -->
                    <Button Style="{StaticResource SidebarMenuButtonStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="28" Height="28" Margin="0,0,0,4">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="3" Canvas.Top="3" Width="14" Height="14"
                                             Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="15" Y1="15" X2="21" Y2="21"
                                          Stroke="White" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Polyline Points="6,14 8,10 11,12 13,8"
                                              Stroke="White" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="시재관리" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════
             메인 콘텐츠 영역
        ══════════════════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- ── 상단 탭바 ── -->
            <TabControl DockPanel.Dock="Top"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Background="White"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#DDDDDD"
                        Height="36"
                        Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Padding"        Value="16,0"/>
                        <Setter Property="FontSize"       Value="13"/>
                        <Setter Property="Background"     Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height"         Value="34"/>
                        <Setter Property="Foreground"     Value="#666666"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="bd"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0,0,0,2"
                                            BorderBrush="Transparent">
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{StaticResource PrimaryBlueBrush}"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource PrimaryBlueBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#F0F4FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="지출관리">
                    <Grid/>
                </TabItem>
                <TabItem Header="목표관리">
                    <Grid/>
                </TabItem>
            </TabControl>

            <!-- ── 도구 모음 (Toolbar) ── -->
            <Border DockPanel.Dock="Top"
                    Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- 년도선택 영역 -->
                        <ColumnDefinition Width="*"/>     <!-- 중앙 버튼 그룹 -->
                        <ColumnDefinition Width="Auto"/>  <!-- 우측 버튼 그룹 -->
                    </Grid.ColumnDefinitions>

                    <!-- 년도 선택 + 새로고침 + 지출기준설정 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="년도선택" VerticalAlignment="Center"
                                   FontSize="12" Foreground="#555" Margin="0,0,6,0"/>
                        <ComboBox Width="70" Height="28" FontSize="12"
                                  ItemsSource="{Binding AvailableYears}"
                                  SelectedItem="{Binding SelectedYear}"
                                  VerticalContentAlignment="Center"/>
                        <Button Content="새로고침"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                Margin="6,0,0,0"/>
                        <Button Content="지출기준설정"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding SetStandardCommand}"
                                Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- 중앙 분석 버튼 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="지출비교분석"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding CompareAnalysisCommand}"
                                Margin="4,0"/>
                        <Button Content="지출상세조회"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding DetailViewCommand}"
                                Margin="4,0"/>
                    </StackPanel>

                    <!-- 우측 등록 버튼 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="지출다중등록"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding MultiAddCommand}"
                                Margin="0,0,4,0"/>
                        <Button Content="지출단일등록"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding SingleAddCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── DataGrid (지출 테이블) ── -->
            <Grid DockPanel.Dock="Bottom" Margin="12,8,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 데이터 행 -->
                <DataGrid Grid.Row="0"
                          Style="{StaticResource MainDataGridStyle}"
                          ItemsSource="{Binding Expenses}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <!-- 행 헤더 아이콘 여백용 -->
                        <DataGridTemplateColumn Width="18" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="분 류 명"  Binding="{Binding Category}"  Width="80"   ElementStyle="{StaticResource CellStyle}"/>
                        <DataGridTextColumn Header="목 표"    Binding="{Binding Goal}"       Width="60"   ElementStyle="{StaticResource CellStyle}"/>
                        <DataGridTextColumn Header="1월"      Binding="{Binding Jan,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="2월"      Binding="{Binding Feb,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="3월"      Binding="{Binding Mar,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="4월"      Binding="{Binding Apr,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="5월"      Binding="{Binding May,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="6월"      Binding="{Binding Jun,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="7월"      Binding="{Binding Jul,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="8월"      Binding="{Binding Aug,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="9월"      Binding="{Binding Sep,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="10월"     Binding="{Binding Oct,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="11월"     Binding="{Binding Nov,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="12월"     Binding="{Binding Dec,  StringFormat={}{0:N0}}" Width="74" ElementStyle="{StaticResource NumCellStyle}"/>
                        <DataGridTextColumn Header="년  간"   Binding="{Binding Annual, StringFormat={}{0:N0}}" Width="90" ElementStyle="{StaticResource NumCellStyleBold}"/>
                        <DataGridTextColumn Header="(%)"      Binding="{Binding Percent}" Width="50" ElementStyle="{StaticResource CellStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 합계 행 -->
                <Border Grid.Row="1"
                        Background="#EEF2F7"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1,0,1,1"
                        Padding="0,4">
                    <Grid x:Name="summaryGrid">
                        <Grid.ColumnDefinitions>
                            <!-- 각 열의 너비를 DataGrid 열과 맞춤 (근사값) -->
                            <ColumnDefinition Width="18"/>    <!-- 행 헤더 -->
                            <ColumnDefinition Width="80"/>    <!-- 분류명 -->
                            <ColumnDefinition Width="60"/>    <!-- 목표 -->
                            <ColumnDefinition Width="74"/>    <!-- 1월 -->
                            <ColumnDefinition Width="74"/>    <!-- 2월 -->
                            <ColumnDefinition Width="74"/>    <!-- 3월 -->
                            <ColumnDefinition Width="74"/>    <!-- 4월 -->
                            <ColumnDefinition Width="74"/>    <!-- 5월 -->
                            <ColumnDefinition Width="74"/>    <!-- 6월 -->
                            <ColumnDefinition Width="74"/>    <!-- 7월 -->
                            <ColumnDefinition Width="74"/>    <!-- 8월 -->
                            <ColumnDefinition Width="74"/>    <!-- 9월 -->
                            <ColumnDefinition Width="74"/>    <!-- 10월 -->
                            <ColumnDefinition Width="74"/>    <!-- 11월 -->
                            <ColumnDefinition Width="74"/>    <!-- 12월 -->
                            <ColumnDefinition Width="90"/>    <!-- 년간 -->
                            <ColumnDefinition Width="50"/>    <!-- (%) -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ▶ 화살표 -->
                        <TextBlock Grid.Column="0" Text="▶" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="{Binding SummaryRow.Category}"
                                   FontWeight="SemiBold" FontSize="12" Padding="6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3"  Text="{Binding SummaryRow.Jan,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="4"  Text="{Binding SummaryRow.Feb,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="5"  Text="{Binding SummaryRow.Mar,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="6"  Text="{Binding SummaryRow.Apr,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="7"  Text="{Binding SummaryRow.May,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="8"  Text="{Binding SummaryRow.Jun,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="9"  Text="{Binding SummaryRow.Jul,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="10" Text="{Binding SummaryRow.Aug,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="11" Text="{Binding SummaryRow.Sep,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="12" Text="{Binding SummaryRow.Oct,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="13" Text="{Binding SummaryRow.Nov,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="14" Text="{Binding SummaryRow.Dec,    StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyle}"/>
                        <TextBlock Grid.Column="15" Text="{Binding SummaryRow.Annual, StringFormat={}{0:N0}}" Style="{StaticResource SumCellStyleBold}"/>
                        <TextBlock Grid.Column="16" Text="{Binding SummaryRow.Percent}" Style="{StaticResource SumCellStyle}"/>
                    </Grid>
                </Border>
            </Grid>

        </DockPanel>
    </Grid>

    <!-- View 전용 리소스 -->
    <Window.Resources>
        <!-- 일반 셀 스타일 -->
        <Style x:Key="CellStyle" TargetType="TextBlock">
            <Setter Property="Padding"            Value="6,3"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="FontSize"           Value="12"/>
        </Style>
        <!-- 숫자 셀 (우정렬) -->
        <Style x:Key="NumCellStyle" TargetType="TextBlock">
            <Setter Property="Padding"              Value="6,3"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="HorizontalAlignment"  Value="Right"/>
            <Setter Property="FontSize"             Value="12"/>
        </Style>
        <!-- 숫자 셀 Bold (년간) -->
        <Style x:Key="NumCellStyleBold" TargetType="TextBlock">
            <Setter Property="Padding"              Value="6,3"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="HorizontalAlignment"  Value="Right"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="FontWeight"           Value="SemiBold"/>
        </Style>
        <!-- 합계 행 셀 -->
        <Style x:Key="SumCellStyle" TargetType="TextBlock">
            <Setter Property="Padding"              Value="6,0"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="HorizontalAlignment"  Value="Right"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="FontWeight"           Value="SemiBold"/>
        </Style>
        <!-- 합계 행 Bold -->
        <Style x:Key="SumCellStyleBold" TargetType="TextBlock">
            <Setter Property="Padding"              Value="6,0"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="HorizontalAlignment"  Value="Right"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="FontWeight"           Value="Bold"/>
            <Setter Property="Foreground"           Value="{StaticResource PrimaryBlueBrush}"/>
        </Style>
    </Window.Resources>
</Window>
