<Window x:Class="AveenoBudget.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AveenoBudget.ViewModels"
        Title="AVEENO Login"
        Width="320" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="White">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <!-- 전체 레이아웃 -->
    <Grid Margin="30,30,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 로고 -->
            <RowDefinition Height="20"/>     <!-- 간격 -->
            <RowDefinition Height="Auto"/>   <!-- 아이디 -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>   <!-- 패스워드 -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- 에러 메시지 -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>   <!-- 버튼 -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- 회원가입 링크 -->
        </Grid.RowDefinitions>

        <!-- ── 로고 ── -->
        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Center"
                   FontSize="42"
                   FontWeight="ExtraBold"
                   FontFamily="Arial Black, Arial"
                   LetterSpacing="4">
            <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00BCD4" Offset="0"/>
                    <GradientStop Color="#2196F3" Offset="1"/>
                </LinearGradientBrush>
            </TextBlock.Foreground>
            AVEENO
        </TextBlock>

        <!-- ── 아이디 입력 ── -->
        <TextBox Grid.Row="2"
                 x:Name="txtUserId"
                 Style="{StaticResource RoundedTextBoxStyle}"
                 Tag="아이디"
                 Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- ── 패스워드 입력 ── -->
        <Grid Grid.Row="4">
            <Border Background="#F5F5F5" CornerRadius="21" x:Name="pwBorder">
                <Grid>
                    <TextBlock x:Name="pwPlaceholder"
                               Text="패스워드"
                               Foreground="#AAAAAA"
                               FontSize="14"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <PasswordBox x:Name="pwBox"
                                 Height="42"
                                 FontSize="14"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Padding="14,0"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 에러 메시지 ── -->
        <TextBlock Grid.Row="6"
                   Text="{Binding ErrorMessage}"
                   Foreground="#E53935"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Visibility="{Binding HasError,
                       Converter={StaticResource BoolToVisConverter}}"/>

        <!-- ── 취소 / 로그인 버튼 ── -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="취소"
                    Style="{StaticResource CancelButtonStyle}"
                    Command="{Binding CancelCommand}"/>

            <Button Grid.Column="2"
                    x:Name="btnLogin"
                    Content="로그인"
                    Style="{StaticResource LoginButtonStyle}"
                    Click="BtnLogin_Click"/>
        </Grid>

        <!-- ── 회원가입 링크 ── -->
        <TextBlock Grid.Row="10"
                   HorizontalAlignment="Center"
                   FontSize="12">
            <Hyperlink Command="{Binding SignUpCommand}"
                       Foreground="{StaticResource PrimaryBlueBrush}">
                &gt; 회원가입 바로가기 &lt;
            </Hyperlink>
        </TextBlock>
    </Grid>

    <Window.Resources>
        <!-- BoolToVisibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>
</Window>
